# Copia este archivo a .env y rellena.
# Si OPENAI_API_KEY está vacío, el análisis usa un fallback heurístico (sin llamar a OpenAI),
# así el prototipo corre out-of-the-box.

PORT=3001

# Zona horaria para las tomas programadas (4:00 y 16:00) y el histórico.
CRON_TZ=America/Santo_Domingo

# Caché de datos: el server consulta n8n a lo sumo cada TTL (ms), sin importar
# cuántos navegadores estén mirando. El front refresca cada 60s.
DATA_CACHE_TTL_MS=45000

# IA — modelo por defecto gpt-4.1-mini
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# ── Fuente de datos real ──
# El prototipo usa datos demo mientras USE_DEMO_DATA=true.
# Pon USE_DEMO_DATA=false para leer de n8n (o Supabase).
USE_DEMO_DATA=true

# Opción A (recomendada): dos webhooks de n8n
#   - N8N_WEBHOOK_CLIENTES  -> devuelve la base de clientes/deudores
#   - N8N_WEBHOOK_LLAMADAS  -> devuelve los resultados de llamadas
# El servidor acepta respuestas tipo [ ... ] o { data:[...] }, y mapea alias de
# columnas (telefono/phone, deuda_total/saldo_total, etc.).
N8N_WEBHOOK_CLIENTES=
N8N_WEBHOOK_LLAMADAS=
N8N_METHOD=GET

# Opción B: Supabase REST
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_TABLE_CLIENTES=clientes
SUPABASE_TABLE_LLAMADAS=resultados_llamadas
